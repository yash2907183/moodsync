# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── ML model cache (large, re-downloaded automatically) ────────────────────────
.cache/
~/.cache/huggingface/
backend/models/

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Next.js / Node ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
